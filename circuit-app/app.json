{
  "expo": {
    "name": "Circuit",
    "slug": "circuit-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.circuit-app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#000000"
    },
    "plugins": [
      "./plugins/with-local-notifications-only-entitlements.js",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#000000"
        }
      ],
      "./plugins/with-skip-metro-ip.js",
      "./plugins/with-device-metro-bundle-url.js",
      "./plugins/with-optional-family-controls-entitlement.js",
      "./plugins/with-pods-resources-tempfile.js",
      "./plugins/with-ios-full-app-icon-catalog.js"
    ]
  }
}
